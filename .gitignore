# ── Ignore everything by default ─────────────────────────────────────────────
*

# ── Whitelist personal config dirs ───────────────────────────────────────────
!quickshell/
!niri/
!hypr/
!kitty/
!ghostty/
!fish/
!btop/
!fastfetch/
!cava/
!gtk-3.0/
!gtk-4.0/
!fontconfig/
!skwd-wall/
!systemd/
!systemd/user/
!systemd/user/cliphist-wipe.service

# ── Whitelist this file and README ───────────────────────────────────────────
!.gitignore
!README.md

# ── Recurse into whitelisted dirs (git requires this) ────────────────────────
!quickshell/**
!niri/**
!hypr/**
!kitty/**
!ghostty/**
!fish/**
!btop/**
!fastfetch/**
!cava/**
!gtk-3.0/**
!gtk-4.0/**
!fontconfig/**
!skwd-wall/**
!systemd/**

# ── Re-ignore generated/runtime files inside whitelisted dirs ─────────────────
quickshell/state/
quickshell/app_usage.json
quickshell/.git/
quickshell/.kilo/
quickshell/.lingma/
quickshell/.roo/
quickshell/.kiro/
quickshell/.codex
quickshell/.roomodes
quickshell/PLANS/
quickshell/YEMI\ SHELL\ DOC/
quickshell/*.broken
quickshell/*.bak
quickshell/watch_*
quickshell/test-binds.js
quickshell/test-parse.js
quickshell/quickshell-bar-diagram.html

kitty/*.old
kitty/kitty.old/
kitty/current-theme.conf

ghostty/skwd-theme
ghostty/themes/ii-auto.bak

fish/fish_variables

skwd-wall/.bootstrapped
skwd-wall/config.json.bak*

hypr/scripts/__pycache__/
hypr/scripts/*.bak
hypr/hyprland.conf.bak*

# ── Common junk ───────────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.qmlc
**/*.jsc
**/*.bak
**/*.bak-*
**/*.old
**/*.broken
**/*.save
**/*.swp
**/*.swo
*~
